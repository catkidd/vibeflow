# FILE: backend/.env.example
# Copy to .env and fill in real values — NEVER commit .env

# ─── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Session ─────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# ─── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── Frontend ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vibeflow

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/callback

# ─── Spotify ─────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=7cd9b0790b064149a99630ecfd85811d
SPOTIFY_CLIENT_SECRET=c61476ab7a7e412883eb5e620f8c375b
SPOTIFY_REDIRECT_URI=http://127.0.0.1:4000/api/spotify/callback

# ─── YouTube Data API v3 ─────────────────────────────────────
YOUTUBE_API_KEY=your-youtube-api-key

# ─── Hugging Face (sentiment fallback) ───────────────────────
HUGGINGFACE_API_KEY=your-huggingface-api-key
