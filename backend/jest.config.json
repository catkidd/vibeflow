{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src", "<rootDir>/__tests__"],
  "testMatch": ["**/__tests__/**/*.test.ts"],
  "transform": { "^.+\\.ts$": "ts-jest" },
  "moduleNameMapper": { "^@/(.*)$": "<rootDir>/src/$1" },
  "clearMocks": true,
  "coverageDirectory": "coverage",
  "collectCoverageFrom": ["src/**/*.ts", "!src/index.ts"]
}
